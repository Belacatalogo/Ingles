# Fluency Clean Rewrite
# Copie para .env.local quando for rodar/buildar o app limpo.
# Não coloque segredos privados aqui. Firebase web config é pública, mas deve ficar organizada.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Código de acesso do preview limpo. Use somente em ambiente controlado.
VITE_ACCESS_CODE=

# Opcional: endpoint do backend privado existente para Azure Pronunciation.
VITE_AZURE_PRONUNCIATION_ENDPOINT=
